# Copy to .env and fill in real values. Never commit .env.

# ---- App ----
NODE_ENV=development
PORT=5000
FRONTEND_ORIGIN=http://localhost:5173

# ---- Database (Postgres) ----
# Leave DB_HOST unset to run the Node backend against the in-memory mock store.
# Also read directly by the Python scripts (predictive_ai.py, storytelling_hybrid_ai.py, train_models.py).
DB_HOST=localhost
DB_PORT=5432
DB_NAME=talend
DB_USER=postgres
DB_PASSWORD=

# ---- JWT / cookies ----
# Required in production; auto-generated (dev only) if unset.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECRET=

# ---- SMTP ----
# Leave unset to run mail in mock-outbox mode (rendered emails written to backend/mail-outbox/).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="MILES Recovery <no-reply@miles.io>"

# ---- AI ----
GROQ_API_KEY=
