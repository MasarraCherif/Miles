# Copy to .env for local dev, or set as a Vercel project env var for deploys.
# Origin only, no trailing slash and no /api suffix.
VITE_API_BASE_URL=http://localhost:5000

# Set to false to hide the OCR document-scan button — match the backend's
# ENABLE_OCR_SCAN so the UI doesn't offer a feature the API will 501.
VITE_ENABLE_OCR_SCAN=true
